<?php

namespace Database\Seeders;

use Illuminate\Database\Seeder;
use App\Models\PurchaseBill;
use App\Models\PurchaseBillItem;
use App\Models\Vendor;
use App\Models\Item;
use App\Models\Branch;
use App\Models\Store;
use Carbon\Carbon;

class PurchaseBillSeeder extends Seeder
{
    public function run(): void
    {
        $vendor = Vendor::first();
        $item = Item::first();
        $branch = Branch::first();
        $store = Store::first();

        if (!$vendor || !$item) {
            return;
        }

        $bills = [
            [
                'bill_no' => 'BILL-2026-001',
                'vendor_id' => $vendor->id,
                'bill_date' => Carbon::parse('2026-02-08'),
                'due_date' => Carbon::parse('2026-03-08'),
                'total_amount' => 8000,
                'tax_amount' => 500,
                'discount_amount' => 0,
                'grand_total' => 8500,
                'paid_amount' => 8500,
                'balance_amount' => 0,
                'status' => 'paid',
                'branch_id' => $branch?->id,
                'store_id' => $store?->id,
            ],
            [
                'bill_no' => 'BILL-2026-002',
                'vendor_id' => $vendor->id,
                'bill_date' => Carbon::parse('2026-02-09'),
                'due_date' => Carbon::parse('2026-03-09'),
                'total_amount' => 6000,
                'tax_amount' => 200,
                'discount_amount' => 0,
                'grand_total' => 6200,
                'paid_amount' => 0,
                'balance_amount' => 6200,
                'status' => 'unpaid',
                'branch_id' => $branch?->id,
                'store_id' => $store?->id,
            ],
            [
                'bill_no' => 'BILL-2026-003',
                'vendor_id' => $vendor->id,
                'bill_date' => Carbon::parse('2026-01-11'),
                'due_date' => Carbon::parse('2026-02-11'),
                'total_amount' => 12000,
                'tax_amount' => 400,
                'discount_amount' => 0,
                'grand_total' => 12400,
                'paid_amount' => 0,
                'balance_amount' => 12400,
                'status' => 'overdue',
                'branch_id' => $branch?->id,
                'store_id' => $store?->id,
            ]
        ];

        foreach ($bills as $billData) {
            $bill = PurchaseBill::create($billData);
            
            PurchaseBillItem::create([
                'purchase_bill_id' => $bill->id,
                'item_id' => $item->id,
                'quantity' => 10,
                'unit_price' => $billData['total_amount'] / 10,
                'tax_amount' => $billData['tax_amount'],
                'amount' => $billData['grand_total'],
            ]);
        }
    }
}
